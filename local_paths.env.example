# OmniNavBench local path configuration -- TEMPLATE.
#
# Setup:
#   1. cp local_paths.env.example local_paths.env
#   2. Edit local_paths.env with the absolute paths on your machine.
#   3. source load_local_paths.sh
#
# Data lives anywhere on disk -- it has no required relationship to this repo.
# Each variable below is a path you point at; the values are read by
# runBench.py and the helper scripts under benchtest*.sh.

# OmniNavBench dataset root.
# Read by runBench.py as the default for --omninavbench-root, and by
# benchtest.sh as the default benchmark dataset root.
# Expected layout (matches the HuggingFace release at AutoLab-SJTU/OmniNavBench):
#   annotations/train/<style>/<robot>/...   (with GT, local scoring OK)
#   annotations/test/<style>/<robot>/...    (sanitized, leaderboard submission only)
#   videos/train/...                        (optional GT replay videos)
OMNINAV_BENCH_DATASET_ROOT="/path/to/OmniNavBench"

# Scene / asset root.
# Read by runBench.py as the default for --scene-root, and by benchtest.sh,
# OmniNav/demo/aliengo_keyboard.py, OmniNav/demo/aliengo_locomotion.py.
# Expected to contain Matterport3D scans + GRScenes USD assets.
OMNINAV_SCENE_ROOT="/path/to/Assets"

# Optional fallback for IsaacLab/source when auto-detection fails.
# Read by the SimulationApp startup chain in:
#   - OmniNav/core/runner.py
#   - OmniNavExt/envset/core/simulation_bootstrap.py
#   - OmniNavExt/envset/standalone.py
# Leave commented out if Isaac Lab is on a standard path on your machine.
#OMNINAV_ISAACLAB_SOURCE="/path/to/IsaacLab/source"
