# OmniNavBench local path configuration -- TEMPLATE.
#
# Setup:
#   1. cp local_paths.env.example local_paths.env
#   2. Edit local_paths.env with the absolute paths on your machine.
#   3. source load_local_paths.sh
#
# Data lives anywhere on disk -- it has no required relationship to this repo.
# Each variable below is a path you point at; the values are read by
# runBench.py and the helper scripts under benchtest*.sh.

# OmniNavBench benchmark dataset root.
# Put the downloaded OmniNavBench dataset anywhere on disk, then point this
# variable to its root. Expected layout:
#   /path/to/OmniNavBench/annotations/train/<style>/<human|dog|car>/...
#   /path/to/OmniNavBench/annotations/test/<style>/<human|dog|car>/...
#   /path/to/OmniNavBench/videos/train/<style>/<human|dog|car>/...  # optional
OMNINAV_BENCH_DATASET_ROOT="/path/to/OmniNavBench"

# Scene / asset root.
# Put scene assets and robot USD assets under this root. Envset relative paths
# such as robots/Carter/carter_v1.usd are resolved relative to this directory.
# Expected examples:
#   /path/to/Assets/robots/Carter/carter_v1.usd
#   /path/to/Assets/robots/aliengo/aliengo_camera.usd
#   /path/to/Assets/robots/h1/h1.usd
#   /path/to/Assets/<Matterport3D or GRScenes assets>
OMNINAV_SCENE_ROOT="/path/to/Assets"

# Must point to IsaacLab/source, and that source directory must contain:
#   omni.isaac.matterport/
# Example:
#   /path/to/IsaacLab/source/omni.isaac.matterport
OMNINAV_ISAACLAB_SOURCE="/path/to/IsaacLab/source"
